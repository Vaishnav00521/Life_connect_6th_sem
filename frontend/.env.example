# LifeConnect Frontend Environment Map
# Copy this file to '.env' or '.env.local' and adjust variables per deployment environment

# The absolute HTTP URL for the Spring Boot Backend API (No trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# The absolute WebSocket URL for the STOMP message broker (Use wss:// in production)
VITE_WS_BASE_URL=ws://localhost:8080
